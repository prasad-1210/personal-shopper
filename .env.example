# LangSmith (set on supervisor + all sub-agents for distributed tracing)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=personal-shopper-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# OpenAI
OPENAI_API_KEY=

# Kroger
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# ── RapidAPI (multi-retailer catalog search) ────────
# Covers: Walmart, Target, Costco, Amazon via Google Shopping
# Register free: rapidapi.com
#   Search: "real-time-product-search" by letscrape-6bRBa3QguO5
#   Subscribe to Basic plan (free tier available)
#   One key covers all RapidAPI-hosted APIs
# Only needed when user selects a non-Kroger retailer
RAPIDAPI_KEY=

# ── Retailer support ────────────────────────────────
# Users say "I shop at walmart/target/costco/amazon" in their message
# Kroger (official API): kroger, ralphs, king soopers, fred meyer
# Catalog only (RapidAPI): walmart, target, costco, amazon
# Default when not specified: kroger

# Spoonacular
SPOONACULAR_API_KEY=

# Edamam (alternative to Spoonacular — 10k req/month free)
# Register at: https://developer.edamam.com/edamam-recipe-api
# Select "Recipe Search API" when creating the app
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Recipe provider: "spoonacular" or "edamam"
RECIPE_PROVIDER=spoonacular

# Set to true to run without any API keys
USE_MOCK_TOOLS=false

# Required by LangGraph standalone server (langgraph build output)
# For local docker-compose these are set automatically
# For Docker Desktop K8s / AKS these come from K8s secret + configmap
REDIS_URI=redis://localhost:6379
DATABASE_URI=postgres://langgraph:langgraph@localhost:5432/langgraph

# ── Sub-agent URLs (multi-agent mode) ───────────────────────────────────────
# Local langgraph dev (each in separate terminal or scripts/dev-multiagent.sh):
NUTRITION_AGENT_URL=http://127.0.0.1:22001
RECIPE_AGENT_URL=http://127.0.0.1:22002
SHOPPING_AGENT_URL=http://127.0.0.1:22003
BUDGET_AGENT_URL=http://127.0.0.1:22004

# Docker Compose (set automatically by docker-compose.yml, no change needed)
# Kubernetes / Helm (one release per agent — see deploy/helm/agents/<name>/values.yaml):
#   LANGGRAPH_URL=http://personal-shopper-supervisor:8000
#   NUTRITION_AGENT_URL=http://personal-shopper-nutrition:8000
#   RECIPE_AGENT_URL=http://personal-shopper-recipe:8000
#   SHOPPING_AGENT_URL=http://personal-shopper-shopping:8000
#   BUDGET_AGENT_URL=http://personal-shopper-budget:8000
# Override any URL per agent via `url:` on that agent in values.yaml

# Optional: LangGraph Platform license (not needed for test/dev mode)
# Contact sales@langchain.dev for production license
# LANGGRAPH_CLOUD_LICENSE_KEY=
