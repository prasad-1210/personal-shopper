# Dev image for docker-compose (langgraph dev per agent).
FROM python:3.12-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml README.md ./
COPY shared ./shared
COPY src ./src
COPY supervisor ./supervisor
COPY agents ./agents

RUN pip install --no-cache-dir -e ".[dev]" "langgraph-cli[inmem]>=0.4.14"
